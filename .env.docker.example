# Compose project name isolates containers/networks/volumes from other stacks.
# Change this if you already run another stack with the same project name.
COMPOSE_PROJECT_NAME=agentic_ai_sdlc

# Bind only to localhost by default to avoid exposing services externally.
BACKEND_BIND_ADDRESS=127.0.0.1
FRONTEND_BIND_ADDRESS=127.0.0.1

# Use non-default host ports to avoid collisions with existing apps.
BACKEND_HOST_PORT=18000
FRONTEND_HOST_PORT=15173

# Startup behavior for backend/start.sh
RUN_MIGRATIONS_ON_STARTUP=true
RESET_DATA_ON_STARTUP=false
RUN_SEEDS_ON_STARTUP=true

# Optional overrides if needed
# BACKEND_PUBLIC_URL=http://127.0.0.1:18000
# VITE_API_BASE_URL=http://127.0.0.1:18000
# VITE_PIPELINE_API_BASE_URL=http://127.0.0.1:18000
