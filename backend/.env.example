APP_NAME=TechMellon Airline Backend
APP_ENV=development
APP_LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./techmellon_airline.db
CORS_ALLOW_ORIGINS=*
# Thesis mode defaults to local-only (no ElevenLabs runtime connection).
ENABLE_ELEVENLABS_AGENTIC=false
BACKEND_PUBLIC_URL=http://127.0.0.1:8000
OPENAI_API_KEY=
JIRA_BASE_URL=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_TOKEN=
JIRA_PROJECT_KEY=
JIRA_TRANSITION_IN_PROGRESS=In Progress
JIRA_TRANSITION_IN_REVIEW=In Review
JIRA_TRANSITION_DONE=Done
JIRA_TRANSITION_BLOCKED=Blocked
ALMAS_ANALYZER_MODEL=openai:gpt-4o-mini
ALMAS_PLANNER_MODEL=openai:gpt-4o-mini
ALMAS_DEVELOPER_MODEL=openai:gpt-4o-mini
ALMAS_FIXER_MODEL=openai:gpt-4o-mini
ALMAS_MAX_REVIEW_REVISIONS=1
ALMAS_DATA_DIR=
ALMAS_ENABLE_COLOR_LOGS=true
ALMAS_LOG_PAYLOAD_MAX_CHARS=6000
ALMAS_REDACT_SENSITIVE_LOGS=true
ALMAS_REPOSITORY_MODE=auto
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BASE_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com
